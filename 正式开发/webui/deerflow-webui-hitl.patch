+  useEffect(() => {
+    const onUavConfirmation = (e: Event) => {
+      const text = (e as CustomEvent<{ text?: string }>).detail?.text;
+      if (!text) return;
+      void sendMessage(threadId, { text, files: [] }, undefined, {
+        additionalKwargs: { hide_from_ui: true },
+      });
+    };
+    window.addEventListener("uav:system-confirmation", onUavConfirmation);
+    return () =>
+      window.removeEventListener("uav:system-confirmation", onUavConfirmation);
+  }, [sendMessage, threadId]);
