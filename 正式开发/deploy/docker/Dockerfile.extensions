# uav_extensions（审批服务 8205 + UI 服务 8213，py3.12）——同一镜像两个入口
# 构建上下文 = 正式开发/（含 uav_extensions/）
# compose 里 approval 用默认 CMD、ui 用 command 覆盖
FROM python:3.12-slim

WORKDIR /app
COPY uav_extensions/pyproject.toml ./
COPY uav_extensions/src ./src
RUN pip install --no-cache-dir .

EXPOSE 8205 8213

# 默认入口=审批服务；UI 服务在 compose 里以 command 覆盖为 ui_service
CMD ["python", "-m", "uav_extensions.approval_service"]
