# 核心三件套 Docker 环境（生产 Linux）——cp 为 .env.docker 后填值
# 凭据勿入库（.env.docker 已在 .gitignore）

# ── 关键网络地址（生产 Linux 必改）──────────────────────────
# 宿主机内网 IP：Higress / 消费方经此 IP + 端口访问 mcp 工具（注册进现网 Nacos）。
# 用 `ip addr` 查服务器内网网卡地址，不是容器 IP、不是 127.0.0.1。
MCP_SERVICE_IP=10.0.0.x
# UI 对外可达地址：确认卡片/视图 view_url 由浏览器打开，必须外部可达
# （宿主 IP:8213 或反代域名如 https://uav.example.com）。
UI_PUBLIC_BASE=http://10.0.0.x:8213

# ── Nacos ───────────────────────────────────────────────────
# 【核心三件套 compose(docker-compose.yml)】用外部现网 Nacos：
NACOS_SERVER_ADDR=192.168.101.21:8998
NACOS_USERNAME=nacos
NACOS_PASSWORD=
NACOS_ENDPOINT_MODE=direct
# 【完整 compose(docker-compose.full.yml)】自带 Nacos，上面 NACOS_SERVER_ADDR/
# MCP_SERVICE_IP 由 full 编排覆盖（nacos:8848 / mcp-services），无需改；
# 但要给自带 Nacos 配鉴权 token（base64 解码 ≥32 字节，用下方命令生成）：
#   python3 -c "import secrets,base64;print(base64.b64encode(secrets.token_bytes(32)).decode())"
NACOS_AUTH_TOKEN=
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=security

# ── Higress（仅完整 compose 用；init-higress.sh 读取）──────────
HIGRESS_GATEWAY_HTTP_PORT=8080
HIGRESS_CONSOLE_PORT=8888
HIGRESS_ADMIN_USER=admin
HIGRESS_ADMIN_PASS=            # 首次在控制台初始化的管理员密码
# 网关消费者：key 必须同时出现在 UAV_TENANT_KEYS 里（后端透传查表才认）
HIGRESS_CONSUMER_NAME=tenant-demo
HIGRESS_CONSUMER_KEY=demo-key-2026-a1b2c3
HIGRESS_CONSUMER_QPM=120

# ── 平台（外部现网，两种 compose 都不部署它，容器直连）──────
DRONE_API_BASE=http://192.168.101.21:10009
DRONE_GATEWAY_BASE=http://demo-lt.geostar.com.cn:11412
DRONE_LOGIN_USERNAME=admin
DRONE_LOGIN_PASSWORD=
# 用户身份透传头（docs/09 关三；平台就绪后填，否则留空=不透传）
DRONE_USER_ID_HEADER=

# ── 鉴权 ────────────────────────────────────────────────────
UAV_MCP_API_KEY=
# 多租户 key 表（JSON 一行）；对外经 Higress 时租户 key 在此查表识别
UAV_TENANT_KEYS={"demo-key-2026-a1b2c3": {"tenant": "tenant-demo", "scopes": ["*"]}}
# 审批 admin key（生产必配强随机值）；四眼动作可选（docs/09）
APPROVAL_ADMIN_KEY=
APPROVAL_FOUR_EYES_ACTIONS=

# ── 真实写开关（生产按需；默认只建任务不下发起飞）────────────
UAV_CREATE_REAL_TASK=0
UAV_REAL_PUBLISH=0
