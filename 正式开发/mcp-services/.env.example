# ── 无人机平台（必配）────────────────────────────────────
DRONE_API_BASE=http://192.168.101.21:10009
DRONE_WORKSPACE_ID=drone

# take_off 确认后在平台创建任务（只建不下发，不会飞）；默认关
UAV_CREATE_REAL_TASK=0
# 下发计划到机场执行（= 真实起飞！）；默认关，开启需现场安全审批
UAV_REAL_PUBLISH=0

# ── 工具面鉴权（生产必配；DeerFlow extensions_config 的 headers 带同值）──
UAV_MCP_API_KEY=
# 多租户 key（docs/07 §4.1）：网关(Higress)消费者 key 透传到此查表识别租户，JSON 格式
# UAV_TENANT_KEYS={"<租户key>": {"tenant": "<租户名>", "scopes": ["*"]}}
UAV_TENANT_KEYS=

# ── 审批服务（生产必配；未配置则进程内本地模式，仅限开发）──
APPROVAL_BASE=http://127.0.0.1:8205

# ── Nacos 注册（可选；不配则只起服务不注册）────────────────
NACOS_SERVER_ADDR=192.168.101.21:8998
NACOS_NAMESPACE=public
NACOS_USERNAME=nacos
NACOS_PASSWORD=
# direct（默认，纯 HTTP）| ref（gRPC 临时实例，需装 nacos-sdk-python）
NACOS_ENDPOINT_MODE=direct
# VPN/多网卡环境显式指定对外 IP
#MCP_SERVICE_IP=

# ── 服务监听 ────────────────────────────────────────────
MCP_HOST=0.0.0.0
PORT_DRONE_DISPATCH=8201
PORT_ROUTE_PLANNING=8202
PORT_PREFLIGHT=8203
PORT_FLIGHT_TASK=8204

# ── 其他 ────────────────────────────────────────────────
# auto：Open-Meteo 自查 → 平台气象兜底；off：只走平台气象
WEATHER_PROVIDER=auto
ROUTE_NAME_PREFIX=低空智察Agent
