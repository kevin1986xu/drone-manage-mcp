# ── 部署环境变量（复制为 .env 后按需修改）────────────────────
# docker compose --env-file .env up -d

# 对外访问 IP（局域网其他机器/网关访问用；单机本地可填 127.0.0.1）
HOST_IP=192.168.101.21

# ── Nacos ────────────────────────────────────────────────────
NACOS_HTTP_PORT=8848      # 控制台/OpenAPI/MCP Registry(v3 admin API) 主端口
NACOS_GRPC_PORT=9848      # 客户端 gRPC（主端口+1000；ref 注册模式需要）

# 鉴权 token：必须是 Base64 串，Base64 解码后长度 ≥ 32 字节（否则 Nacos 启动报错）
# 生成自己的：  echo -n "你的至少32位随机串xxxxxxxxxxxxxxx" | base64
# 下面示例解码为 "ThisIsMyCustomSecretKey0123456789"（33 字节，仅供测试，生产务必替换）
NACOS_AUTH_TOKEN=VGhpc0lzTXlDdXN0b21TZWNyZXRLZXkwMTIzNDU2Nzg5
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=security

# 控制台管理员密码：Nacos 3.x 首次访问控制台时设置（本变量仅供 Higress 连接 Nacos 用，
# 请填成你首次登录时设定的密码；默认账号 nacos）
NACOS_ADMIN_PASSWORD=nacos

# ── Higress ──────────────────────────────────────────────────
HIGRESS_GATEWAY_HTTP_PORT=80     # 网关 HTTP 入口（含聚合后的 MCP 端点）
HIGRESS_GATEWAY_HTTPS_PORT=443   # 网关 HTTPS 入口
HIGRESS_CONSOLE_PORT=8001        # Higress 控制台（映射到容器内 8080）
