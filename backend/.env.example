# ── Agent 模式 ───────────────────────────────────────────────
# auto（默认）：有 LLM_API_KEY 走 LangGraph ReAct；否则 scripted 兜底路由（可脱网演示）
# 也可强制指定：llm / scripted
AGENT_MODE=auto

# ── LLM（OpenAI 兼容接口，默认阿里云百炼 Qwen）────────────────
# 私有化部署时把 BASE_URL 指到内网 vLLM/SGLang 即可，其余不动
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# ── 前端跨域 ────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── 真实业务数据源（drone-manage 若依模块，可选）──────────────
# 配置后图斑/设备/航线规划/气象走真实接口，失败自动回落 mock（L1 降级）；
# 不配置则全 mock（脱网演示）。
DRONE_API_BASE=http://192.168.101.21:10009
# take_off 确认后是否真在平台创建飞行任务（平台自动调度器可能下发执行，默认关）
# DRONE_CREATE_REAL_TASK=1
# DRONE_WORKSPACE_ID=drone
# 气象：默认后端自查 Open-Meteo（免费无 key）→ 平台接口 → mock；mock=禁用出网
# WEATHER_PROVIDER=auto

# ── Nacos MCP Registry（可选）────────────────────────────────
# 配置后 MCP server 以 streamable-http 常驻（默认端口 8101-8104）并自动
# 注册到 Nacos MCP Registry（HTTP v3 admin API，Nacos ≥3.0，已在 3.2.1 验证）；
# 不配置则保持 stdio 本地模式。
NACOS_SERVER_ADDR=192.168.101.21:8998
NACOS_NAMESPACE=public
NACOS_USERNAME=nacos
NACOS_PASSWORD=
# NACOS_ENDPOINT_MODE=direct      # direct（默认，纯 HTTP 零 gRPC 依赖）| ref（gRPC 临时实例 + REF 引用，需主端口+1000 的 gRPC 可达）
# MCP_TRANSPORT=streamable-http   # stdio | sse | streamable-http
# MCP_SERVICE_IP=                 # 注册到 Nacos 的对外 IP（VPN/多网卡环境建议显式指定）
# MCP_PORT=                       # 覆盖单个 server 的监听端口
